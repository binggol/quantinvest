# Copy to .env and fill in actual values. Do NOT commit .env.

TUSHARE_TOKEN=your_tushare_token_here

# Inside container these are the mounted paths
QLIB_DATA_PATH=/app/qlib_data/cn_data
PARQUET_DIR=/app/qlib_data/csv_tmp/tushare_daily
STOCK_META_DB=/app/data/stock_meta.db

# Flask
PORT=5055
HOST=0.0.0.0

# Daily auto-update (24h format)
DAILY_UPDATE_HOUR=21
DAILY_UPDATE_MINUTE=0

# Refresh stock_basic (industry / new listings) every N days
STOCK_META_REFRESH_DAYS=7
